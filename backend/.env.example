# BrandOS Environment Configuration
# Copy this file to .env and fill in your values.

# --- LLM / AI ---
GOOGLE_API_KEY=""
GEMINI_API_KEY=""
LANGSMITH_API_KEY=""
# LangSmith / LangChain tracing (optional)
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="brandos-content-pipeline"

# --- Database ---
DATABASE_URL="sqlite+aiosqlite:///./brandos.db"

# --- Auth ---
JWT_SECRET="change-me-to-a-random-secret"
JWT_ALGORITHM="HS256"

# --- App ---
ENV="development"
DEBUG=true

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT="100/minute"
RATE_LIMIT_AUTH="20/minute"
RATE_LIMIT_CONTENT_GENERATE="10/minute"

# --- CORS ---
CORS_ORIGINS='["http://localhost:3000"]'
